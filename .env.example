# AI API 키 (필수)
# 사용하는 AI 서비스의 API 토큰을 입력하세요
# OpenAI:    https://platform.openai.com
# Anthropic: https://console.anthropic.com
OPENAI_API_KEY=여기에_OpenAI_API_토큰_입력
# ANTHROPIC_API_KEY=여기에_Anthropic_API_토큰_입력

# Codeforces API (선택: 본인 계정 소스 코드 import용)
# 발급: https://codeforces.com/settings/api
CODEFORCES_API_KEY=
CODEFORCES_API_SECRET=

# DB 설정 (로컬은 아래 항목 불필요 — SQLite 자동 사용)
# DB_TYPE=postgres
# DB_NAME=boj_review
# DB_USER=boj_user
# DB_PASSWORD=your_password
# DB_HOST=localhost
# DB_PORT=5432
# DB_SOCKET=/cloudsql/PROJECT:REGION:INSTANCE
